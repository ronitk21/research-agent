# =============================================================================
# RESEARCH AGENT - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# Do not commit .env files to version control

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL database connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL="postgresql://research_user:your_password@localhost:5432/research_agent"

# =============================================================================
# REDIS CONFIGURATION (for queue management)
# =============================================================================
# Redis connection details
REDIS_HOST="localhost"
REDIS_PORT="6379"
# Alternative: Full Redis URL (overrides host/port if set)
REDIS_URL="redis://localhost:6379"

# =============================================================================
# API KEYS (Required for external services)
# =============================================================================
# OpenAI API key for LLM functionality
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key-here"

# News API key for article fetching
# Get your API key from: https://newsapi.org/
NEWS_API_KEY="your-news-api-key-here"

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Port for the backend server
PORT="3000"

# CORS origin for frontend (set to your frontend URL in production)
# For local development, this should be your Next.js dev server URL
CORS_ORIGIN="http://localhost:3001"

# Node environment (development/production)
NODE_ENV="development"

# =============================================================================
# FRONTEND CONFIGURATION (Next.js)
# =============================================================================
# Backend API URL for frontend to connect to
# In development: http://localhost:3000
# In production: https://your-backend-domain.com
NEXT_PUBLIC_API_URL="http://localhost:3000"

# =============================================================================
# DOCKER COMPOSE CONFIGURATION
# =============================================================================
# PostgreSQL credentials for Docker Compose
POSTGRES_USER="research_user"
POSTGRES_PASSWORD="your_secure_password_here"

# =============================================================================
# PRODUCTION DEPLOYMENT NOTES
# =============================================================================
# For production deployment:
# 1. Use strong, unique passwords
# 2. Set NODE_ENV="production"
# 3. Use HTTPS URLs for CORS_ORIGIN and NEXT_PUBLIC_API_URL
# 4. Use managed database services (e.g., Railway, Supabase, PlanetScale)
# 5. Use managed Redis services (e.g., Upstash, Redis Cloud)
# 6. Store sensitive values in your hosting platform's environment variables

# =============================================================================
# DOCKER COMPOSE ADDITIONAL CONFIGURATION
# =============================================================================
# Additional PostgreSQL configuration
POSTGRES_DB="research_agent"
POSTGRES_PORT="5432"

# Redis configuration for Docker
REDIS_PASSWORD="your_redis_password_here"
REDIS_PORT="6379"

# Backend port configuration
BACKEND_PORT="3000"

